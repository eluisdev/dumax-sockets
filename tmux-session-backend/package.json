{
  "name": "tmux-monitor-server",
  "version": "1.0.0",
  "description": "TmuxMonitor backend — Express + Socket.io + SSH2",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch server.ts --exec \"ts-node\" server.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
