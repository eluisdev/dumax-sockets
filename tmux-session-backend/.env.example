# Puerto del backend (Render lo asigna automáticamente vía $PORT)
PORT=4001

# Origenes permitidos en CORS (separa con coma para varios)
# Ej. en producción:  https://tu-app.netlify.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Servidores SSH disponibles (JSON array en una sola línea)
# - Para servidores con LLAVE en producción → usa "keyEnv": "NOMBRE_VAR_ENV"
#   y guarda el contenido del archivo id_ed25519 en esa variable de entorno.
# - Para servidores con LLAVE en local → usa "keyPath": "./keys/id_ed25519"
# - Para servidores con CONTRASEÑA → usa "password": "..."
SSH_SERVERS=[{"id":"wialon","label":"Wialon","host":"165.22.88.108","port":22,"user":"staging","keyEnv":"WIALON_SSH_KEY","passphrase":"changeme"},{"id":"dumax-v4","label":"Dumax V4","host":"67.205.152.9","port":22,"user":"deployer","password":"changeme"},{"id":"dumax-v2","label":"Dumax V2","host":"104.236.146.29","port":22,"user":"staging","password":"changeme"}]

# Llave privada SSH del servidor Wialon (contenido completo del archivo, incluyendo BEGIN/END)
# En Render, pega el contenido tal cual del archivo. En .env local puedes dejarlo vacío
# y usar keyPath en SSH_SERVERS para apuntar a ./keys/id_ed25519
WIALON_SSH_KEY=
